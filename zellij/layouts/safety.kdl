layout {
    pane split_direction="vertical" {
        pane cwd="~/Projects/Safety" name="main" size="60%"
        pane split_direction="horizontal" stacked=true size="40%" {
            pane cwd="~/Projects/Safety" name="terminal"
            pane cwd="~/Projects/Safety" name="terminal"
        }
    }
    pane size=1 borderless=true {
        plugin location="zellij:compact-bar"
    }
}
