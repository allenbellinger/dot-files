layout {
    pane split_direction="vertical" {
        pane cwd="~/Projects" name="main" size="70%"
        pane split_direction="horizontal" stacked=true size="30%" {
            pane cwd="~/.config" name="config"
            pane cwd="~/Projects" name="terminal"
            pane cwd="~/Projects" name="terminal"
        }
    }
}
